#!/usr/bin/perl -w

use FindBin;
use lib "$FindBin::Bin/../../..//perl_lib";

######################################################################
#
#
######################################################################

=pod

=for Pod2Wiki

=head1 NAME

B<generate_apacheconf_for_anubis> - Create the apache config files needed for EPrints, including diversion via Anubis

=head1 SYNOPSIS

B<generate_apacheconf_for_anubis> [B<options>] [I<repository_id>]

B<generate_apacheconf_for_anubis> --replace [repoid]

=head1 DESCRIPTION

This script re-generates the config files to include Anubis in your Apache configuration.

This script assumes your EPrints instance has already been configured to support HTTPS and has
an SSL specific apache config file in archive/REPO_ID/ssl/securevhost.conf as per https://wiki.eprints.org/w/How_to_use_EPrints_with_HTTPS

If you have changed a repository's configuration (hostname/port/path) you can
update the configuration for that repository with:

 generate_apacheconf_for_anubis --replace [repoid]

Anubis sits in front of EPrints and selectively forwards requests to EPrints, or blocks them.

This will result in:
 - EPrints on HTTP (no SSL) on port 3000, not visible to the outside world
 - A reverse proxy on port 443 that forwards to the Anubis service on port 8923
 - Port 80 as a simple redirect to 443.
 - Anubis should be configured to forward requests to localhost:3000

Via the following config files:

/etc/httpd/conf.d/eprints.conf includes /opt/eprints3/cfg/apache.conf
/opt/eprints3/cfg/apache.conf includes /opt/eprints3/cfg/apache/*.conf
/opt/eprints3/cfg/apache/REPOID.conf  listens on port 3000
/opt/eprints3/cfg/apache/redirect.conf will redirect port 80 to 443

/etc/httpd/conf.d/eprints-ssl.conf includes /opt/eprints3/archives/*/ssl/securevhost.conf
/opt/eprints3/archives/*/ssl/securevhost.conf configures certificates and will include /opt/eprints3/cfg/apache_ssl/[REPOID].conf which will actually configure anubis

=head2 Adding to Apache Configuration

To enable EPrints you must add the following line to your main Apache
configuration file (I</etc/httpd/conf/httpd.conf>), modifying EPRINTS_PATH as appropriate :

 Include EPRINTS_PATH/cfg/apache.conf

To enable secure (HTTPS) you must add the following line to your SSL
VirtualHost, modifying EPRINTS_PATH as appropriate:

 Include EPRINTS_PATH/cfg/apache_ssl.conf

=head1 ARGUMENTS

=over 8

=item repository_id

Optionally update the given repository's apache configuration only. Will only
replace an existing configuration file with the --replace option.

=back

=head1 OPTIONS

=over 8

=item B<--replace>

Replace existing configuration files, overwriting any changes made.

=item B<--system>

Update the system configuration file, overwriting any changes made.

=item B<--help>

Print a brief help message and exit.

=item B<--man>

Print the full manual page and then exit.

=item B<--quiet>

Be vewwy vewwy quiet. This option will suppress all output unless an error occurs.

=item B<--verbose>

Explain in detail what is going on.
May be repeated for greater effect.

=item B<--version>

Output version information and exit.

=back   

=head1 FILES

=over 4

=item B<EPRINTS/cfg/apache.conf>

Loads the EPrints environment and repository-specific configuration files.

=item B<EPRINTS/cfg/apache_ssl.conf>

Loads the repository-specific SSL configuration files.

=item B<EPRINTS/cfg/apache/[repoid].conf>

A <VirtualHost> that responds to the configured hostname and port of the
repository.

=item B<EPRINTS/cfg/apache_ssl/[repoid].conf>

A <Location> that responds to the configured https_root of the repository.

=item B<EPRINTS/archives/[repoid]/cfg.d/10_base.pl>

Default location for host and path directives used to build the Apache
configuration files.

=back


=cut


use EPrints;

use strict;
use Getopt::Long;
use Pod::Usage;
use Digest::MD5;

my $version = 0;
my $verbose = 0;
my $quiet = 0;
my $help = 0;
my $man = 0;
my $replace = 0;
my $system = 0;

Getopt::Long::Configure("permute");

GetOptions( 
	'help|?' => \$help,
	'man' => \$man,
	'version' => \$version,
	'verbose+' => \$verbose,
	'silent' => \$quiet,
	'quiet' => \$quiet,
	'replace' => \$replace,
	'system' => \$system,
) || pod2usage( 2 );
EPrints::Utils::cmd_version( "generate_apacheconf_for_anubis" ) if $version;
pod2usage( 1 ) if $help;
pod2usage( -exitstatus => 0, -verbose => 2 ) if $man;
pod2usage( 2 ) if( scalar @ARGV > 1 );

our( $repository_id ) = @ARGV;

our $noise = 1;
$noise = 0 if( $quiet );
$noise = 1+$verbose if( $verbose );

#cjg Write a more simple conf if only one language involved?

# Set STDOUT to auto flush (without needing a \n)
$|=1;

my $eprints = EPrints->new;

# Load up the repositories
my %reps = ();
foreach my $id ( $eprints->repository_ids() )
{
	$reps{$id} = $eprints->repository( $id, db_connect => 0); 
	EPrints->abort( "Error loading $id" ) if !defined $reps{$id};
}

my $base_path = EPrints::Config::get( "base_path" );
my $archives_path = "$base_path/archives";
my $perl_lib = "$base_path/perl_lib";
my $apache_eprints_conf = EPrints::Config::get( "cfg_path" )."/apache.conf";
# my $anubis_ssl_conf = EPrints::Config::get( "cfg_path" )."/apache_ssl.conf";
my $perl_module_isolation = EPrints::Config::get( "perl_module_isolation" );
my $perl_module_isolation_conf = EPrints::Config::get( "cfg_path" )."/perl_module_isolation.conf";
my $perl_module_isolation_vhost_conf = EPrints::Config::get( "cfg_path" )."/perl_module_isolation_vhost.conf";

my $first_run = !-e $apache_eprints_conf;

my $restart_required = 0;

my $inc_path = "$base_path/cfg/apache";
my $inc_ssl_path = "$base_path/cfg/apache_ssl";

EPrints->system->mkdir( $inc_path );
EPrints->system->mkdir( $inc_ssl_path );

# we are using the same port for all hosts because they will be virtualhosts on port 3000 - allowing anubis to just forward
# everything to port 3000 and then apache sort it out to the respective eprints repositories
my $localport = 3000;

if( ($system && $replace) || !-e $apache_eprints_conf )
{
	my $conf = <<END;
#
# apache.conf include file for EPrints
#
# Any changes made here will be lost if you run generate_apacheconf_for_anubis
# with the --replace --system options
#

# EPrints moved to be internal-only, with Anubis facing the outside world.
Listen [::1]:$localport

# Load the perl modules & repository configurations
PerlSwitches -I$perl_lib
Include $base_path/cfg/perl_module_isolation.conf

# Load the per-repository apache configuration
Include $inc_path/*.conf

END
	my $backup = EPrints->system->write_config_file( $apache_eprints_conf, $conf, BACKUP => 1 );
	if( $backup )
	{
		print "Wrote $backup\n" if $noise >= 1;
	}
	print "Wrote $apache_eprints_conf\n" if( $noise >= 1 );

	$restart_required = 1;
}

######write perl module isolation conf
if($perl_module_isolation)
{
	my $conf= <<END;	
##This file is included by apache.conf -- Do not edit this file directly.
##You should edit the perl_module_isolation flag in $base_path/perl_lib/EPrints/SystemSettings.pm, then run $base_path/bin/generate_apacheconf_for_anubis --system --replace to regenerate this file.

##The following two lines are commented out to turn the perl_module_isolation ON (Each repository now has it's own perl interpreter and have access to its own perl modules only.)
#PerlModule EPrints
#PerlPostConfigHandler +EPrints::post_config_handler
END
	EPrints->system->write_config_file( $perl_module_isolation_conf, $conf, BACKUP => 0);
	print "Wrote $perl_module_isolation_conf\n" if( $noise >= 1 );


        my $conf_vhost= <<END;   
##This file is included by each repository's apache conf -- Do not edit this file directly.
##You should edit the perl_module_isolation flag in $base_path/perl_lib/EPrints/SystemSettings.pm, then run $base_path/bin/generate_apacheconf_for_anubis --system --replace to regenerate this file.

##The following three lines turn the perl_module_isolation ON (Each repository now has it's own perl interpreter and have access to its own perl modules only.)
PerlOptions +Parent
PerlSwitches -I$base_path/perl_lib
PerlModule EPrints
END
	EPrints->system->write_config_file( $perl_module_isolation_vhost_conf, $conf_vhost, BACKUP => 0);
	print "Wrote $perl_module_isolation_vhost_conf\n" if( $noise >= 1 );
}
else ## perl module_isolation off
{
	my $conf= <<END;        
##This file is included by apache.conf -- Do not edit this file directly.
##You should edit the perl_module_isolation flag in $base_path/perl_lib/EPrints/SystemSettings.pm, then run $base_path/bin/generate_apacheconf_for_anubis --system --replace to regenerate this file.

##The following two lines turn the perl_module_isolation OFF (All repositories now sharing a single perl interpreter and have access to all perl modules.)
PerlModule EPrints
PerlPostConfigHandler +EPrints::post_config_handler
END
	EPrints->system->write_config_file( $perl_module_isolation_conf, $conf, BACKUP => 0);
	print "Wrote $perl_module_isolation_conf\n" if( $noise >= 1 );


        my $conf_vhost= <<END;   
##This file is included by each repository's apache conf -- Do not edit this file directly.
##You should edit the perl_module_isolation flag in $base_path/perl_lib/EPrints/SystemSettings.pm, then run $base_path/bin/generate_apacheconf_for_anubis --system --replace to regenerate this file.

##The following three lines are commented out to turn the perl_module_isolation OFF (All repositories now sharing a single perl interpreter and have access to all perl modules.)
#PerlOptions +Parent
#PerlSwitches -I$base_path/perl_lib
#PerlModule EPrints
END
	EPrints->system->write_config_file( $perl_module_isolation_vhost_conf, $conf_vhost, BACKUP => 0);
	print "Wrote $perl_module_isolation_vhost_conf\n" if( $noise >= 1 );

}




####################################################
# 
#   Write apache conf files for each repository
#
####################################################

# Bodge - we want to call EPrints::Apache::apache_conf but we want to overide a handful of repo config options. This class lets us do just that
package FakeRepo;

sub new {
	my ($class, $real_repo, $port) = @_;
	
	my $self = bless {}, $class;

	$self->{real_repo} = $real_repo;
	$self->{port} =  $port;

	return $self;
}

sub get_id{
	my ($self) = @_;

	return $self->{real_repo}->get_id;
}

sub get_conf { return config( @_ ); }
sub config {
	my ($self, $config_name) = @_;

	if($config_name eq "port"){
		#we want to listen on http but on port 3000
		return $self->{port};
	}

	if($config_name eq "http_url"){
		#pretend to be HTTP so we get the full HTTP-only config file
		return "http://literallyAnything";
	}

	if($config_name eq "aliases"){
		#pretend there aren't any aliases so we just get a virtualhost block for port 3000
		return undef;
	}

	# fall back to real config
	return $self->{real_repo}->get_conf($config_name);
}


foreach my $repository ( values %reps ) 
{
	my $id = $repository->get_id();

	next if $repository_id && $repository_id ne $id;

	my $cfg_path = $repository->get_conf( "config_path" );

	my $eprints_apache_conf = "$inc_path/$id.conf";
	my $http_to_https_redirect_conf = "$inc_path/${id}_http_to_https_redirect.conf";
	my $anubis_ssl_conf = "$inc_ssl_path/$id.conf";
	my $javascript_auto_dir = $repository->get_conf( "base_path" ) . "/archives/$id/cfg/static/javascript/auto/";
	my $uploadmethod_file_max_size = $javascript_auto_dir . "99_uploadmethod_file_max_size.js";

	my $securehost = $repository->get_conf( "securehost" );
	

	if( $replace || !-e $eprints_apache_conf )
	{
		# all hosts will be on the same internal port with apache virtualhosts sorting them out after anubis forwards requests to $localport (3000 by default)
		my $fake_repo = FakeRepo->new($repository, $localport);
		my $conf = EPrints::Apache::apache_conf( $fake_repo );

		# add the secure option because we will be presented to the world on https, even if internally it's http
		$conf =~ s/PerlSetVar EPrints_ArchiveID $id/PerlSetVar EPrints_ArchiveID $id\n    PerlSetVar EPrints_Secure yes/;

		# add customised access_log which logs real IP from the other side of our own reverse proxy
		# TODO is this accidentally red hat specific?
		$conf =~ s@Include /opt/eprints3/cfg/perl_module_isolation_vhost.conf@Include /opt/eprints3/cfg/perl_module_isolation_vhost.conf\n    CustomLog logs/access_log "%{X-Real-Ip}i %l %u %t \\"%r\\" %>s %b \\"%{Referer}i\\" \\"%{User-Agent}i\\""@;
    	
		my $backup = EPrints->system->write_config_file( $eprints_apache_conf, $conf );
		if( $backup )
		{
			print "Wrote $backup\n" if( $noise >= 1 );
		}
		print "Wrote $eprints_apache_conf\n" if( $noise >= 1 );
	}

	if( $replace || !-e $http_to_https_redirect_conf ){
		# if we're alreayd configured with HTTPS then this will be a simple redirect listening on port 80
		my $redirect_to_https = EPrints::Apache::apache_conf( $repository );

		my $backup = EPrints->system->write_config_file( $http_to_https_redirect_conf, $redirect_to_https );
		if( $backup )
		{
			print "Wrote $backup\n" if( $noise >= 1 );
		}
		print "Wrote $http_to_https_redirect_conf\n" if( $noise >= 1 );


		$restart_required = 1;
	}

	if( $replace || !-e $anubis_ssl_conf ){

		# block of config that should be included inside the <virtualhost> which is configured for ssl on port 443
		my $anubis =<<EOC;
# HTTPS listener that forwards to Anubis

# These headers need to be set or else Anubis will
# throw an "admin misconfiguration" error.
RequestHeader set "X-Real-Ip" expr=%{REMOTE_ADDR}
RequestHeader set X-Forwarded-Proto "https"
RequestHeader set "X-Http-Version" "%{SERVER_PROTOCOL}s"

ProxyPreserveHost On

ProxyRequests Off
ProxyVia Off

# Replace 8923 with the port Anubis listens on
ProxyPass / http://[::1]:8923/
ProxyPassReverse / http://[::1]:8923/

EOC
		my $backup = EPrints->system->write_config_file( $anubis_ssl_conf, $anubis );
		if( $backup )
		{
			print "Wrote $backup\n" if( $noise >= 1 );
		}
		print "Wrote $anubis_ssl_conf\n" if( $noise >= 1 );
	}


	my $js = "max_size = " . $repository->get_conf( 'max_upload_filesize' ) . ";";
	EPrints->system->mkdir( $javascript_auto_dir );
	EPrints->system->write_config_file( $uploadmethod_file_max_size, $js );
}

if( $first_run )
{
	print "\nAdd the following line to your apache configuration:\n\tInclude $apache_eprints_conf\n";
}

if( $restart_required )
{
	print "\nYou must restart apache for any changes to take effect!\n" if( $noise >= 1 );
}
else
{
	print "\nNo files were changed. For more information do ./generate_apacheconf_for_anubis --man\n";
}

